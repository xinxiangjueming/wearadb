    <!-- PairingScreen -->
    <string name="pair_title">设备配对</string>
    <string name="pair_wireless_title">Android 11+ 无线配对</string>
    <string name="pair_step1">1. 在目标设备上打开「开发者选项」→「无线调试」</string>
    <string name="pair_step2">2. 点击「使用配对码配对设备」</string>
    <string name="pair_step3">3. 输入弹窗中显示的「配对码」和「IP 地址及端口」</string>
    <string name="pair_port_note">注意：端口是「配对用配对码」弹窗中的端口，不是「无线调试」页面的端口</string>
