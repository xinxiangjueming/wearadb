    <!-- PairingScreen -->
    <string name="pair_title">裝置配對</string>
    <string name="pair_wireless_title">Android 11+ 無線配對</string>
    <string name="pair_step1">1. 在目標裝置上開啟「開發人員選項」→「無線偵錯」</string>
    <string name="pair_step2">2. 點選「使用配對碼配對裝置」</string>
    <string name="pair_step3">3. 輸入彈出視窗中顯示的「配對碼」和「IP 位址及連接埠」</string>
    <string name="pair_port_note">注意：連接埠是「配對用配對碼」彈出視窗中的連接埠，不是「無線偵錯」頁面的連接埠</string>
    <string name="label_pair_code">配對碼</string>
    <string name="pair_code_placeholder">6 位數字</string>
    <string name="btn_pairing">配對</string>
    <string name="btn_pairing_progress">配對中…</string>
    <string name="pair_failed">配對失敗</string>
    <string name="pair_tips">提示</string>
    <string name="pair_tip1">1. 確認手機與目標裝置連接相同 WiFi</string>
    <string name="pair_tip2">2. 確認輸入的是「配對用配對碼」連接埠，不是「無線偵錯」連接埠</string>
    <string name="pair_tip3">3. 配對碼每次開啟都會重新產生，請使用最新的</string>
    <string name="pair_tip4">4. 若配對持續失敗，可先在電腦上執行 adb pair &lt;ip&gt;:&lt;port&gt; &lt;code&gt; 進行配對</string>
